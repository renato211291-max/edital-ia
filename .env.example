# =====================================================
# EDITAL IA — Variáveis de Ambiente
# =====================================================
# Copie este arquivo para .env.local e preencha com suas chaves
# NUNCA commite o arquivo .env.local no git

# -----------------------------------------------------
# Supabase
# -----------------------------------------------------
# Pegar em: Settings > API no dashboard do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...

# -----------------------------------------------------
# Anthropic (Claude API)
# -----------------------------------------------------
# Pegar em: console.anthropic.com > API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# -----------------------------------------------------
# Asaas (Pagamentos)
# -----------------------------------------------------
# Pegar em: app.asaas.com > Integrações > Chave de API
# Use a chave de SANDBOX para desenvolvimento
ASAAS_API_KEY=$aact_xxxxx
ASAAS_ENV=sandbox  # ou 'production' em produção
ASAAS_WEBHOOK_TOKEN=token_secreto_para_validar_webhooks

# -----------------------------------------------------
# Resend (E-mail transacional)
# -----------------------------------------------------
# Pegar em: resend.com > API Keys
RESEND_API_KEY=re_xxxxx
RESEND_FROM_EMAIL=naoresponda@licitarestrategy.com.br

# -----------------------------------------------------
# Aplicação
# -----------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000  # produção: https://app.licitarestrategy.com.br
NEXT_PUBLIC_APP_NAME=Edital IA
NODE_ENV=development

# -----------------------------------------------------
# PNCP (Portal Nacional de Contratações Públicas)
# -----------------------------------------------------
# API pública, não requer autenticação
PNCP_BASE_URL=https://pncp.gov.br/api/consulta/v1

# -----------------------------------------------------
# Sentry (Monitoramento de erros) — opcional no MVP
# -----------------------------------------------------
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
